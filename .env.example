# Copy to `.env` and fill in before `docker compose up -d`. See docs/docker.md.

# --- Tailscale (required — it is the security boundary) ----------------------
# A Tailscale auth key from https://login.tailscale.com/admin/settings/keys .
# A reusable + ephemeral key is convenient for a long-lived node; tag it with an
# ACL tag you control (the compose file expects the node to be a normal member).
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx

# MagicDNS hostname for this node. The UI ends up at
# https://<TS_HOSTNAME>.<your-tailnet>.ts.net
TS_HOSTNAME=powdermonkey

# --- The project PowderMonkey drives ----------------------------------------
# Absolute path on the host to the repo you want to drive. It is mounted into
# the container and worktrees are cut from it.
REPO_PATH=/absolute/path/to/your/project

# --- Credentials mounted into the container (defaults usually fine) ----------
# Claude Code login/config dir (holds the session `claude --remote` dispatch uses).
CLAUDE_CONFIG_DIR=~/.claude
# git identity used for commits/pushes from worktrees.
GIT_CONFIG=~/.gitconfig
