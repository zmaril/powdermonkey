  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@elysiajs/eden": "^1.4.9",
    "@mantine/core": "^7.15.0",
    "@mantine/hooks": "^7.15.0",
    "@sinclair/typebox": "0.34.49",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dockview-react": "^7.0.2",
    "drizzle-orm": "^0.38.0",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.29",
    "playwright-core": "^1.49.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.30.0"
  }
