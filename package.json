{
  "name": "powdermonkey",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "powdermonkey": "bin/powdermonkey.ts"
  },
  "files": [
    "bin",
    "src",
    "public",
    "drizzle",
    "docs",
    "design.md",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "serve": "bun run bin/powdermonkey.ts serve",
    "attach": "bun run bin/powdermonkey.ts attach",
    "build:web": "bun build src/web/main.tsx --outdir public/assets --target browser",
    "build:compile": "bun run build:web && rm -rf dist && mkdir -p dist && bun build --compile bin/powdermonkey.ts --outfile dist/powdermonkey && cp -r public drizzle dist/ && cp node_modules/@electric-sql/pglite/dist/postgres.wasm node_modules/@electric-sql/pglite/dist/postgres.data dist/",
    "db:generate": "drizzle-kit generate",
    "check": "biome check src && bun run scripts/lint-strings.ts",
    "size": "git ls-files 'src/**/*.ts' 'src/**/*.tsx' | xargs wc -l | tail -1",
    "test": "for f in tests/*.test.ts; do echo \"# $f\"; bun test \"$f\" || exit 1; done",
    "prepublishOnly": "bun run build:web"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.2.17",
    "@elysiajs/eden": "^1.4.9",
    "@mantine/core": "^7.15.0",
    "@mantine/hooks": "^7.15.0",
    "@sinclair/typebox": "0.34.49",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dockview-react": "^7.0.2",
    "drizzle-orm": "^0.38.0",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.29",
    "es-toolkit": "^1.49.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-pattern": "^5.9.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.30.0"
  }
}
