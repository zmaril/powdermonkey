{
  "name": "powdermonkey",
  "version": "0.0.1",
  "private": true,
  "description": "Single-operator command center for running many claude -p workers at once",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "start": "bun run src/server/index.ts",
    "build:web": "bun build src/web/main.tsx --outdir public/assets --target browser",
    "db:generate": "drizzle-kit generate",
    "test": "bun test",
    "lint": "biome check src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.23",
    "@assistant-ui/react-streamdown": "^0.3.4",
    "@electric-sql/pglite": "^0.5.3",
    "@elysiajs/eden": "^1.4.9",
    "@mantine/core": "^7.13.0",
    "@mantine/hooks": "^7.13.0",
    "@streamdown/code": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.4",
    "elysia": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "streamdown": "^2.5.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/bun": "^1.3.14",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.6.0"
  }
}
