{
  "name": "powdermonkey",
  "version": "0.0.0",
  "type": "module",
  "bin": {
    "powdermonkey": "bin/powdermonkey.ts"
  },
  "files": [
    "bin",
    "src",
    "public",
    "drizzle",
    "docs",
    "design.md",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "bun run --watch src/server/index.ts",
    "serve": "bun run bin/powdermonkey.ts serve",
    "attach": "bun run bin/powdermonkey.ts attach",
    "build:web": "bun build src/web/main.tsx --outdir public/assets --target browser",
    "tauri": "tauri",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "build:compile": "bun run build:web && rm -rf dist && mkdir -p dist && bun build --compile bin/powdermonkey.ts --outfile dist/powdermonkey && cp -r public drizzle dist/ && cp node_modules/@electric-sql/pglite/dist/pglite.wasm node_modules/@electric-sql/pglite/dist/pglite.data node_modules/@electric-sql/pglite/dist/initdb.wasm dist/",
    "storybook": "storybook dev -p 6006 --no-open",
    "build:storybook": "storybook build",
    "visual": "LOST_PIXEL_DISABLE_TELEMETRY=1 lost-pixel",
    "visual:update": "LOST_PIXEL_DISABLE_TELEMETRY=1 lost-pixel update",
    "db:generate": "drizzle-kit generate",
    "hooks:install": "bun run scripts/install-hooks.ts",
    "typecheck": "tsc --noEmit",
    "check": "biome check --error-on-warnings src && bun run scripts/lint-strings.ts && bun run scripts/lint-dock-theme.ts && bun run scripts/lint-spacing.ts",
    "size": "git ls-files 'src/**/*.ts' 'src/**/*.tsx' | xargs wc -l | tail -1",
    "test": "for f in tests/*.test.ts; do echo \"# $f\"; out=$(bun test --preload ./tests/_teardown.ts \"$f\" 2>&1); echo \"$out\"; if echo \"$out\" | grep -qE '^ *[1-9][0-9]* fail'; then exit 1; fi; if ! echo \"$out\" | grep -qE 'Ran [0-9]+ test'; then exit 1; fi; done && for f in tests/*.test.tsx; do [ -e \"$f\" ] || continue; echo \"# $f\"; out=$(bun test --preload ./tests/_teardown.ts --preload ./tests/dom-preload.ts \"$f\" 2>&1); echo \"$out\"; if echo \"$out\" | grep -qE '^ *[1-9][0-9]* fail'; then exit 1; fi; if ! echo \"$out\" | grep -qE 'Ran [0-9]+ test'; then exit 1; fi; done",
    "prepublishOnly": "bun run build:web"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@electric-sql/pglite": "^0.5.4",
    "@elysiajs/eden": "^1.4.9",
    "@entl/node": "file:../entl/crates/entl-node",
    "@fontsource-variable/fira-code": "^5.2.7",
    "@formkit/auto-animate": "^0.9.0",
    "@mantine/core": "^7.15.0",
    "@mantine/hooks": "^7.15.0",
    "@pierre/diffs": "^1.2.12",
    "@pierre/trees": "^1.0.0-beta.5",
    "@sinclair/typebox": "0.34.49",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/db": "^0.6.14",
    "@tanstack/react-db": "^0.1.92",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "dockview-react": "^7.0.2",
    "dompurify": "^3.4.11",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.29",
    "es-toolkit": "^1.49.0",
    "marked": "^18.0.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ts-pattern": "^5.9.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@happy-dom/global-registrator": "^20.10.6",
    "@storybook/react-vite": "^10.4.6",
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "happy-dom": "^20.10.6",
    "lost-pixel": "3.22.0",
    "playwright-core": "^1.61.1",
    "storybook": "^10.4.6",
    "vite": "^8.1.3"
  }
}
