#!/bin/sh
# Full local gate — the same checks CI enforces, run before the commit lands so
# agents catch failures here instead of ping-ponging with remote CI.
# Bypass with `git commit --no-verify`. Activate with:
#   git config core.hooksPath .githooks
#
# The test suite + compile run in .githooks/pre-push, not here: `bun run test`
# shells out to `git worktree add`, which fails while a commit holds
# .git/index.lock. pre-push has no such lock and still gates before remote/CI.
set -e
run() { printf '\n\033[1m▶ %s\033[0m\n' "$*"; "$@"; }

run bun run check
run bun run typecheck
run ./.githooks/run-straitjacket
