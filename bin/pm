#!/usr/bin/env sh
# pm — PowderMonkey operator helper. A thin wrapper over the `bun run` scripts so
# the common operator commands are short and memorable. Run it from anywhere; it
# resolves the repo root from its own location.
#
#   pm attach [target]   # attach a tmux client to the PowderMonkey socket
#   pm serve             # launch the supervisor server in tmux (idempotent)
#
# Put it on your PATH (e.g. `ln -s "$PWD/bin/pm" ~/.local/bin/pm`) and `pm attach`
# works from anywhere.
set -e

root=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cmd=${1:-}
[ "$#" -gt 0 ] && shift

case "$cmd" in
  attach) exec bun run "$root/src/server/attach.ts" "$@" ;;
  serve)  exec bun run "$root/src/server/supervise.ts" "$@" ;;
  ""|-h|--help|help)
    echo "usage: pm <attach|serve> [args]" >&2
    [ "$cmd" = "" ] && exit 2 || exit 0 ;;
  *)
    echo "pm: unknown command '$cmd' (try: attach, serve)" >&2
    exit 2 ;;
esac
